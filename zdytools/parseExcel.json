{
  "openapi": "3.1.0",
  "info": {
    "title": "Multi-Sheet Excel Parser",
    "description": "解析 Excel 并按 Sheet 名称分类返回数据",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "http://host.docker.internal:18091"
    }
  ],
  "paths": {
    "/parse": {
      "post": {
        "operationId": "parseMultiSheetExcel",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file_url": {
                    "type": "string",
                    "description": "Excel 文件的下载链接"
                  }
                },
                "required": ["file_url"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "返回按 Sheet 分类的 JSON 数据",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "totalSheets": { "type": "integer" },
                    "sheets": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": { "type": "object" }
                      },
                      "description": "键为 Sheet 名称，值为该表内容的数组"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
